RewriteEngine On
RewriteBase /

# 1. Index-Bereinigung: /index oder /index.html zu /
RewriteRule ^index(?:\.(html|php))?$ / [R=301,L,NC]

# 2. Externe Umleitung: /seite.html (oder .php) -> /seite
# Verhindert Duplicate Content und sorgt für saubere URLs in Suchmaschinen
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/+(.+?)\.(html|php)[\s\?] [NC]
RewriteRule ^ %1 [R=301,L]

# 3. Interne Umschreibung: /seite -> /seite.html
# Wenn die Datei als .html existiert
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^/]+)/?$ $1.html [L]

# 4. Interne Umschreibung: /seite -> /seite.php
# Falls keine .html existiert, schauen wir nach .php
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^/]+)/?$ $1.php [L]

# 5. Eigene 404-Seite
ErrorDocument 404 /404.html
RewriteEngine On
RewriteBase /

# AUSNAHME: Admin-Verzeichnis ignorieren
# Ersetze "admin" durch den tatsächlichen Namen deines Admin-Ordners
RewriteCond %{REQUEST_URI} ^/admin [NC]
RewriteRule ^ - [L]

# 1. Index-Bereinigung: /index oder /index.html zu /
RewriteRule ^index(?:\.(html|php))?$ / [R=301,L,NC]

# 2. Externe Umleitung: /seite.html -> /seite
RewriteCond %{REQUEST_URI} !^/admin [NC]
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/+(.+?)\.(html|php)[\s\?] [NC]
RewriteRule ^ %1 [R=301,L]

# 3. Interne Umschreibung: /seite -> /seite.html
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^/]+)/?$ $1.html [L]

# 4. Interne Umschreibung: /seite -> /seite.php
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^/]+)/?$ $1.php [L]

# 5. Eigene 404-Seite
ErrorDocument 404 /404.html